{
  "name": "postmaker-skill",
  "version": "0.1.0",
  "description": "Local-first agent skill for turning repository evidence into launch-ready posts.",
  "type": "module",
  "bin": {
    "postmaker-skill": "./bin/postmaker-skill.js"
  },
  "scripts": {
    "test": "node --test",
    "check": "node scripts/check.js",
    "build": "node scripts/check.js && node --check bin/postmaker-skill.js",
    "smoke": "node bin/postmaker-skill.js fixtures/release-evidence.json --format markdown",
    "package:smoke": "node scripts/package-smoke.js",
    "release:check": "npm run check && npm test && npm run build && npm run smoke && npm run package:smoke"
  },
  "keywords": [
    "agent-skill",
    "launch",
    "content",
    "dry-run",
    "repo-evidence"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogerchappel/postmaker-skill.git"
  },
  "bugs": {
    "url": "https://github.com/rogerchappel/postmaker-skill/issues"
  },
  "homepage": "https://github.com/rogerchappel/postmaker-skill#readme",
  "engines": {
    "node": ">=18"
  },
  "files": [
    "bin/",
    "docs/",
    "fixtures/",
    "src/",
    "SKILL.md",
    "README.md",
    "LICENSE"
  ]
}
